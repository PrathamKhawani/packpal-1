{
  "version": 2,
  "builds": [
    {
      "src": "DAIICT/Index.html",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/DAIICT/$1"
    }
  ]
}
