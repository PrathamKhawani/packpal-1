{
  "version": 2,
  "builds": [
    {
      "src": "DAIICT/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/",
      "dest": "/DAIICT/Index.html"
    },
    {
      "src": "/(.*\\.(css|js|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf))",
      "dest": "/DAIICT/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/DAIICT/Index.html"
    }
  ]
}
